# ─────────────────────────────────────────────────────────────────
# TransactFlowOS — Firebase Environment Variables TEMPLATE
#
# This file IS committed to GitHub. It shows teammates what
# variables they need to set, WITHOUT any real values.
#
# To use:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real Firebase values in .env
#   3. Never commit .env  (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
